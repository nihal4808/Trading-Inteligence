// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Weekly planning and focus (now linked to roadmap sections)
model WeeklyPlan {
  id                   String   @id @default(cuid())
  roadmapSectionId     String?  @unique // Link to roadmap week (optional for backward compatibility)
  weekStartDate        DateTime
  weekEndDate          DateTime
  focusTopic           String
  learningRoadmap      String?
  movieRecommendations String?
  bookRecommendations  String?
  weeklyGoals          String?
  progressNotes        String?
  completionPercentage Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  section              RoadmapSection? @relation(fields: [roadmapSectionId], references: [id], onDelete: SetNull)

  @@index([weekStartDate])
  @@index([roadmapSectionId])
}

// Daily tasks and productivity (now can link to roadmap tasks)
model DailyTask {
  id              String   @id @default(cuid())
  roadmapTaskId   String?  // Link to roadmap task (optional, can be manually created)
  date            DateTime
  title           String
  description     String?
  category        String   // trading, learning, psychology, health, etc.
  priority        String   @default("medium") // high, medium, low
  completed       Boolean  @default(false)
  completedAt     DateTime?
  timeSpent       Int?     // minutes
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  roadmapTask     RoadmapTask? @relation(fields: [roadmapTaskId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([completed])
  @@index([category])
  @@index([roadmapTaskId])
}

// Trade journal
model Trade {
  id              String   @id @default(cuid())
  date            DateTime
  symbol          String
  tradeType       String   // long, short, scalp, swing, etc.
  entryPrice      Float
  quantity        Int
  exitPrice       Float?
  profitLoss      Float?
  winRate         Int?     // percentage
  strategy        String?
  emotionalState  String?  // confident, anxious, neutral, etc.
  mistakes        String?
  lessons         String?
  tags            String?  // comma-separated
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([symbol])
  @@index([tradeType])
}

// Diary and reflections
model DiaryEntry {
  id              String   @id @default(cuid())
  date            DateTime
  title           String?
  content         String?
  tags            String?  // comma-separated tags for filtering/search
  mood            Int      @default(5) // 1-10 scale
  confidence      Int      @default(5) // 1-10 scale
  stress          Int      @default(5) // 1-10 scale
  tradingPerformance String?
  emotionalNotes  String?
  gratitude       String?
  goals           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([title])
}

// Learning and education tracking
model LearningLog {
  id              String   @id @default(cuid())
  date            DateTime
  topic           String
  lessonTitle     String
  source          String?  // book, course, youtube, etc.
  duration        Int?     // minutes
  keyTakeaways    String?
  difficulty      String?  // beginner, intermediate, advanced
  completed       Boolean  @default(false)
  proficiencyLevel Int    @default(0) // 0-100
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([topic])
}

model MediaItem {
  id              String      @id @default(cuid())
  title           String
  category        String?
  mediaType       String
  status          String      @default("unwatched")
  rating          Int?
  review          String?
  lessonsLearned  String?
  emotionalImpact String?
  watchedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([mediaType])
  @@index([category])
  @@index([title])
}

// Structured learning roadmap (weeks -> days -> tasks)
model RoadmapSection {
  id          String   @id @default(cuid())
  title       String
  description String?
  weekNumber  Int
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks            RoadmapTask[]
  generatedWeeklyTask GeneratedWeeklyTask?
  weeklyPlan        WeeklyPlan?

  @@unique([weekNumber])
  @@index([order])
}

model RoadmapTask {
  id                   String   @id @default(cuid())
  sectionId            String
  title                String
  description          String?
  category             String
  dayNumber            Int
  dayLabel             String?
  estimatedDuration    Int?
  recommendedResources String?
  completed            Boolean  @default(false)
  completedAt          DateTime?
  status               String   @default("not_started") // not_started, in_progress, completed, reviewed
  progressPercentage   Int      @default(0)
  notes                String?
  order                Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  section              RoadmapSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  generatedDailyTask   GeneratedDailyTask?
  reviews              RoadmapReview[]
  dailyTasks           DailyTask[]

  @@index([sectionId])
  @@index([dayNumber])
  @@index([completed])
  @@index([status])
  @@index([category])
  @@index([order])
}

model GeneratedWeeklyTask {
  id                  String   @id @default(cuid())
  roadmapSectionId    String   @unique
  title               String
  summary             String?
  progressPercentage  Int      @default(0)
  completed           Boolean  @default(false)
  status              String   @default("Not Started")
  review              String?
  reflection          String?
  emotionalReflection String?
  notes               String?
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  roadmapSection      RoadmapSection @relation(fields: [roadmapSectionId], references: [id], onDelete: Cascade)
  taskReview          TaskReview?

  @@index([completed])
  @@index([status])
}

model GeneratedDailyTask {
  id               String   @id @default(cuid())
  roadmapTaskId    String   @unique
  title            String
  description      String?
  category         String
  status           String   @default("Not Started")
  completed        Boolean  @default(false)
  review           String?
  reflection       String?
  notes            String?
  confidenceLevel  Int?
  difficultyLevel  Int?
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  roadmapTask      RoadmapTask @relation(fields: [roadmapTaskId], references: [id], onDelete: Cascade)
  taskReview       TaskReview?

  @@index([completed])
  @@index([status])
  @@index([category])
}

model TaskReview {
  id                   String   @id @default(cuid())
  taskType             String
  generatedDailyTaskId String?  @unique
  generatedWeeklyTaskId String?  @unique
  title                String?
  review               String?
  reflection           String?
  emotionalState       String?
  confidenceLevel      Int?
  difficultyLevel      Int?
  lessonsLearned       String?
  improvementIdeas     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  dailyTask            GeneratedDailyTask? @relation(fields: [generatedDailyTaskId], references: [id], onDelete: Cascade)
  weeklyTask           GeneratedWeeklyTask? @relation(fields: [generatedWeeklyTaskId], references: [id], onDelete: Cascade)

  @@index([taskType])
  @@index([createdAt])
}

// Review and reflection tracking for roadmap tasks
model RoadmapReview {
  id                String   @id @default(cuid())
  roadmapTaskId     String
  review            String?  // What was learned
  reflection        String?  // Personal reflection
  mood              Int?     // 1-10 emotional state
  confidenceLevel   Int?     // 1-10 how confident in learning
  difficultyLevel   Int?     // 1-10 how difficult was the task
  lessonsLearned    String?  // Key takeaways
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  roadmapTask       RoadmapTask @relation(fields: [roadmapTaskId], references: [id], onDelete: Cascade)

  @@index([roadmapTaskId])
  @@index([createdAt])
}

model RoadmapProgress {
  id                   String   @id @default("roadmap")
  totalTasks           Int
  completedTasks       Int
  completionPercentage Int
  currentWeek          Int
  currentDay           Int
  updatedAt            DateTime @updatedAt
}
